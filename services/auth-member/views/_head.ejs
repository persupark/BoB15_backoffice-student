<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root { --brand:#4f46e5; --bg:#f8fafc; --ink:#0f172a; --mut:#64748b; --line:#e2e8f0; }
  * { box-sizing:border-box; }
  body { margin:0; font-family:-apple-system,'Apple SD Gothic Neo','Noto Sans KR',sans-serif; background:var(--bg); color:var(--ink); }
  header { background:#fff; border-bottom:1px solid var(--line); padding:14px 20px; display:flex; align-items:center; gap:16px; }
  header .logo { font-weight:800; color:var(--brand); font-size:18px; text-decoration:none; }
  header nav { margin-left:auto; display:flex; gap:14px; }
  header a { color:var(--mut); text-decoration:none; font-size:14px; }
  main { max-width:640px; margin:32px auto; padding:0 20px; }
  .card { background:#fff; border:1px solid var(--line); border-radius:12px; padding:24px; margin-bottom:16px; }
  h1 { font-size:22px; margin:0 0 12px; }
  label { display:block; font-size:13px; color:var(--mut); margin:12px 0 4px; }
  input, textarea { width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:8px; font-size:15px; }
  button { margin-top:16px; width:100%; padding:11px; background:var(--brand); color:#fff; border:0; border-radius:8px; font-size:15px; font-weight:600; cursor:pointer; }
  .err { background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; border-radius:8px; padding:10px 12px; font-size:14px; margin-bottom:8px; }
  .ok  { background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; border-radius:8px; padding:10px 12px; font-size:14px; margin-bottom:8px; }
  .muted { color:var(--mut); font-size:13px; }
  .photo { border:1px solid var(--line); border-radius:12px; overflow:hidden; margin-bottom:14px; background:#fff; }
  .photo img { width:100%; display:block; }
  .photo .meta { padding:10px 14px; font-size:14px; }
  code { background:#f1f5f9; padding:2px 6px; border-radius:6px; font-size:13px; word-break:break-all; }
</style>
