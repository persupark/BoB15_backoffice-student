<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --text:#37352F; --text-2:#787774; --bg:#ffffff; --bg-sidebar:#fbfbfa;
    --hover:#efefed; --border:#e9e9e7; --accent:#2383e2; --accent-hover:#0b6fcc;
    --danger:#eb5757; --danger-bg:#fdecea; --danger-border:#f5c6c6;
    --callout-bg:#fbf3db; --callout-border:#f1e2b0;
    --radius:6px; --sidebar-w:240px;
  }
  * { box-sizing:border-box; }
  body {
    margin:0; color:var(--text); background:var(--bg); font-size:14px; line-height:1.5;
    font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Segoe UI',Helvetica,'Noto Sans KR',Arial,sans-serif;
  }
  .shell { display:flex; min-height:100vh; }
  .sidebar { width:var(--sidebar-w); flex-shrink:0; background:var(--bg-sidebar); border-right:1px solid var(--border);
    display:flex; flex-direction:column; padding:14px 8px; }
  .workspace { display:flex; align-items:center; gap:8px; padding:6px 8px 14px; font-weight:600; font-size:14px; }
  .sidebar-nav { display:flex; flex-direction:column; gap:1px; flex:1; }
  .sidebar-nav a { display:flex; align-items:center; gap:8px; padding:6px 8px; border-radius:var(--radius);
    color:var(--text); text-decoration:none; font-size:14px; }
  .sidebar-nav a:hover { background:var(--hover); }
  .sidebar-footer { border-top:1px solid var(--border); margin-top:10px; padding:10px 8px 4px;
    display:flex; align-items:center; justify-content:space-between; }
  .sidebar-footer .who-name { font-size:13px; color:var(--text-2); }
  .sidebar-footer form { margin:0; }
  .sidebar-footer button { background:none; border:none; color:var(--text-2); font-size:12px; cursor:pointer;
    padding:4px 8px; border-radius:var(--radius); }
  .sidebar-footer button:hover { background:var(--hover); color:var(--text); }

  .content { flex:1; min-width:0; }
  .callout { display:flex; gap:8px; align-items:flex-start; background:var(--callout-bg); border:1px solid var(--callout-border);
    border-radius:var(--radius); padding:10px 14px; font-size:13px; color:#56481f; margin:24px 40px 0; }
  .content-inner { max-width:880px; margin:0 auto; padding:32px 40px 64px; }
  .auth-card { max-width:360px; margin:96px auto 0; }
  .auth-card input { width:100%; }

  h1 { font-size:1.7em; font-weight:700; margin:0 0 22px; letter-spacing:-0.01em; }
  h2 { font-size:1.05em; font-weight:600; margin:36px 0 12px; color:var(--text); }
  table { width:100%; border-collapse:collapse; font-size:14px; margin-bottom:8px; }
  th, td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--border); vertical-align:top; }
  th { color:var(--text-2); font-weight:500; font-size:11.5px; text-transform:uppercase; letter-spacing:.03em; white-space:nowrap; }
  tbody tr:hover td { background:var(--hover); }

  label { display:block; font-size:13px; color:var(--text-2); margin:12px 0 4px; }
  input, select, textarea { padding:6px 10px; border:1px solid var(--border); border-radius:var(--radius);
    font-size:14px; background:#fff; color:var(--text); font-family:inherit; }
  input:focus, select:focus, textarea:focus { outline:2px solid var(--accent); outline-offset:-1px; border-color:var(--accent); }
  button { padding:6px 14px; background:var(--hover); color:var(--text); border:1px solid var(--border);
    border-radius:var(--radius); font-size:13px; font-weight:500; cursor:pointer; }
  button:hover { background:#e3e2e0; }
  button.primary { background:var(--accent); color:#fff; border-color:var(--accent); }
  button.primary:hover { background:var(--accent-hover); }

  .err { background:var(--danger-bg); color:#c0362c; border:1px solid var(--danger-border); border-radius:var(--radius);
    padding:10px 12px; font-size:14px; margin-bottom:16px; }
  .muted { color:var(--text-2); font-size:13px; }
  .badge { display:inline-block; padding:2px 8px; border-radius:99px; font-size:11px; background:var(--hover); color:var(--text-2); }
  .badge.overdue { background:#fde9e9; color:#c0362c; }
  .stat { display:inline-block; margin-right:40px; }
  .stat b { font-size:2em; display:block; font-weight:700; }
  code { background:var(--hover); padding:2px 6px; border-radius:4px; font-size:12.5px; word-break:break-all;
    font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
  a { color:var(--accent); }
</style>
