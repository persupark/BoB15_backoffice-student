{
  "name": "boblog-grc-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "boblog — 모의 SNS 서비스 + 개인정보처리시스템(백오피스) 실습 랩",
  "engines": {
    "node": ">=22.9.0"
  },
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "migrate": "node --env-file-if-exists=.env scripts/migrate.js",
    "seed": "node --env-file-if-exists=.env services/seed/seed.js",
    "seed:vuln": "node --env-file-if-exists=.env services/seed/seed-vuln.js",
    "seed:students": "node --env-file-if-exists=.env services/seed/seed-students.js",
    "dev:auth": "node --env-file-if-exists=.env services/auth-member/src/server.js",
    "dev:photo": "node --env-file-if-exists=.env services/photo/src/server.js",
    "dev:vuln": "node --env-file-if-exists=.env services/backoffice-vuln/src/server.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
