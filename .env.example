# ── 데이터베이스/세션 ─────────────────────────────────────────────
DATABASE_URL=postgres://boblog:boblog@localhost:5432/boblog
REDIS_URL=redis://localhost:6379

# ── 암호화 ──────────────────────────────────────────────────────
# 32바이트 base64 마스터키. 데모 전용 — 실환경에서는 KMS/Vault 등 외부 키관리로 교체.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY_B64=Ym9ibG9nLWRlbW8ta2V5IWJvYmxvZy1kZW1vLWtleSE=

# ── 서비스 간 내부 인증 ──────────────────────────────────────────
SERVICE_TOKEN=dev-internal-service-token

# ── 세션/접근통제 ────────────────────────────────────────────────
SESSION_SECRET=dev-session-secret-change-me
SESSION_IDLE_MINUTES=30
LOGIN_MAX_FAILS=5
LOCK_MINUTES=30

# ── 포트/경로 ────────────────────────────────────────────────────
AUTH_PORT=3001
PHOTO_PORT=3002
VULN_PORT=3200
PHOTO_BASE_URL=http://localhost:3002
UPLOAD_DIR=./data/uploads
